# ── Google Gemini ──────────────────────────────────────────────────────────────
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-pro

# ── Supabase (optional — for persisting sessions) ──────────────────────────────
# https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ── Kaltura Avatar iframe URL ──────────────────────────────────────────────────
NEXT_PUBLIC_KALTURA_AVATAR_URL=https://meet.avatar.us.kaltura.ai/your-agent-path
KALTURA_AVATAR_API_KEY=your_kaltura_avatar_api_key_here
