# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Google Gemini ──────────────────────────────────────────────────────────────
# Paste your Gemini API key below. Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=AIzaSyAF5mAJpEqdDnB9SCZTWCIbf_cuH0072v8
GEMINI_MODEL=gemini-2.5-pro
# Public versions used by client-side Gemini call (static export / GitHub Pages)
NEXT_PUBLIC_GEMINI_API_KEY=AIzaSyAF5mAJpEqdDnB9SCZTWCIbf_cuH0072v8
NEXT_PUBLIC_GEMINI_MODEL=gemini-2.0-flash
# Empty for local dev; /kaltura-connect-future is set by GitHub Actions for the build
NEXT_PUBLIC_BASE_PATH=

# Supabase — get these from your project dashboard → Settings → API
# https://supabase.com/dashboard/project/<your-project>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Kaltura Avatar — iframe embed URL (NEXT_PUBLIC so the client can read it)
# The URL below is the pre-configured Kaltura Connect 2025 agent.
NEXT_PUBLIC_KALTURA_AVATAR_URL=https://meet.avatar.us.kaltura.ai/695cd19880ea19bd1b816a08/talk-to-agent?aiclid=EttXcIcr&flow_id=agent-90
